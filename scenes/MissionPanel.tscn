[gd_scene load_steps=2 format=3 uid="uid://mission_panel_scene"]

[sub_resource type="GDScript" id="GDScript_missionpanel"]
script/source = "## MissionPanel.tscn のスクリプト
## ミッション進捗確認パネル。
extends Control

const COLOR_TEXT_MAIN  = Color(0.227, 0.165, 0.102)
const COLOR_TEXT_SUB   = Color(0.478, 0.416, 0.353)
const COLOR_SUCCESS    = Color(0.220, 0.580, 0.235)
const COLOR_FAIL       = Color(0.820, 0.200, 0.200)
const COLOR_PENDING    = Color(0.478, 0.416, 0.353)

func _ready() -> void:
	_apply_dark_theme()
	GameManager.phase_changed.connect(_on_phase_changed)
	_build_ui()

func _apply_dark_theme() -> void:
	var theme = Theme.new()
	theme.set_color('font_color', 'Label', COLOR_TEXT_MAIN)
	self.theme = theme

func _build_ui() -> void:
	var overlay = ColorRect.new()
	overlay.color = Color(0, 0, 0, 0.4)
	overlay.anchor_right = 1.0
	overlay.anchor_bottom = 1.0
	add_child(overlay)

	var panel = Panel.new()
	panel.name = 'MissionCard'
	panel.position = Vector2(240, 80)
	panel.size = Vector2(800, 540)
	var style = StyleBoxFlat.new()
	style.bg_color = Color(0.980, 0.984, 0.941)
	style.set_border_width_all(3)
	style.border_color = Color(0.290, 0.565, 0.851)
	style.corner_radius_top_left = 16
	style.corner_radius_top_right = 16
	style.corner_radius_bottom_left = 16
	style.corner_radius_bottom_right = 16
	style.shadow_color = Color(0, 0, 0, 0.2)
	style.shadow_size = 8
	panel.add_theme_stylebox_override('panel', style)
	add_child(panel)

	var vbox = VBoxContainer.new()
	vbox.name = 'VBox'
	vbox.position = Vector2(40, 36)
	vbox.size = Vector2(720, 468)
	vbox.add_theme_constant_override('separation', 14)
	panel.add_child(vbox)

	# タイトル行
	var title_row = HBoxContainer.new()
	vbox.add_child(title_row)

	var title_icon = Label.new()
	title_icon.text = '📋'
	title_icon.add_theme_font_size_override('font_size', 22)
	title_row.add_child(title_icon)

	var title = Label.new()
	title.text = ' ミッション進捗'
	title.add_theme_font_size_override('font_size', 22)
	title.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
	title_row.add_child(title)

	var day_badge = Label.new()
	day_badge.name = 'DayBadge'
	day_badge.add_theme_font_size_override('font_size', 14)
	day_badge.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	day_badge.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	day_badge.horizontal_alignment = HORIZONTAL_ALIGNMENT_RIGHT
	title_row.add_child(day_badge)

	var sep = HSeparator.new()
	vbox.add_child(sep)

	var mission_scroll = ScrollContainer.new()
	mission_scroll.name = 'MissionScroll'
	mission_scroll.size_flags_vertical = Control.SIZE_EXPAND_FILL
	vbox.add_child(mission_scroll)

	var mission_list = VBoxContainer.new()
	mission_list.name = 'MissionList'
	mission_list.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	mission_list.add_theme_constant_override('separation', 8)
	mission_scroll.add_child(mission_list)

	var sep2 = HSeparator.new()
	vbox.add_child(sep2)

	# 現在パラメータ一覧（小さく）
	var params_row = HBoxContainer.new()
	params_row.name = 'ParamsRow'
	params_row.alignment = BoxContainer.ALIGNMENT_CENTER
	params_row.add_theme_constant_override('separation', 16)
	vbox.add_child(params_row)

	var next_btn = Button.new()
	next_btn.text = '翌日へ進む →'
	next_btn.add_theme_font_size_override('font_size', 16)
	var btn_style = StyleBoxFlat.new()
	btn_style.bg_color = Color(0.290, 0.565, 0.851)
	btn_style.corner_radius_top_left = 10
	btn_style.corner_radius_top_right = 10
	btn_style.corner_radius_bottom_left = 10
	btn_style.corner_radius_bottom_right = 10
	next_btn.add_theme_stylebox_override('normal', btn_style)
	next_btn.add_theme_color_override('font_color', Color.WHITE)
	next_btn.pressed.connect(_on_next_day_pressed)
	vbox.add_child(next_btn)

func _on_phase_changed(phase: GameManager.Phase) -> void:
	if phase != GameManager.Phase.MISSION:
		return
	visible = true
	_update_missions()
	_animate_in()

func _update_missions() -> void:
	var panel = get_node_or_null('MissionCard')
	if panel == null:
		return

	var day_badge = panel.get_node_or_null('VBox/HBoxContainer/DayBadge')
	if day_badge:
		day_badge.text = '%d日目 / 30日' % GameManager.current_day

	var mission_list = panel.get_node_or_null('VBox/MissionScroll/MissionList')
	if mission_list == null:
		return
	for child in mission_list.get_children():
		child.queue_free()

	var missions_path = 'res://data/missions.json'
	if not FileAccess.file_exists(missions_path):
		return
	var file = FileAccess.open(missions_path, FileAccess.READ)
	var json = JSON.new()
	if json.parse(file.get_as_text()) != OK:
		file.close()
		return
	file.close()
	var main_missions = json.get_data().get('main_missions', [])

	for mission in main_missions:
		var entry = _create_mission_entry(mission)
		mission_list.add_child(entry)

	# 現在パラメータ
	_update_params_row(panel)

func _create_mission_entry(mission: Dictionary) -> Control:
	var bg = Panel.new()
	bg.custom_minimum_size = Vector2(0, 64)
	var mission_id = mission.get('id', '')
	var is_done    = mission_id in MissionManager.completed_missions
	var is_failed  = mission_id in MissionManager.failed_missions
	var is_passed  = GameManager.current_day > mission.get('day', 999)

	var bg_style = StyleBoxFlat.new()
	if is_done:
		bg_style.bg_color = Color(0.220, 0.580, 0.235, 0.12)
		bg_style.border_color = Color(0.220, 0.580, 0.235, 0.5)
	elif is_failed:
		bg_style.bg_color = Color(0.820, 0.200, 0.200, 0.10)
		bg_style.border_color = Color(0.820, 0.200, 0.200, 0.5)
	else:
		bg_style.bg_color = Color(1, 1, 1, 0.4)
		bg_style.border_color = Color(0.816, 0.847, 0.753)
	bg_style.set_border_width_all(1)
	bg_style.corner_radius_top_left = 8
	bg_style.corner_radius_top_right = 8
	bg_style.corner_radius_bottom_left = 8
	bg_style.corner_radius_bottom_right = 8
	bg.add_theme_stylebox_override('panel', bg_style)

	var hbox = HBoxContainer.new()
	hbox.position = Vector2(12, 8)
	hbox.size = Vector2(696, 48)
	hbox.add_theme_constant_override('separation', 12)
	bg.add_child(hbox)

	# 状態アイコン
	var status = Label.new()
	status.add_theme_font_size_override('font_size', 20)
	status.custom_minimum_size = Vector2(28, 0)
	if is_done:
		status.text = '✅'
	elif is_failed:
		status.text = '❌'
	elif is_passed:
		status.text = '⏰'
	else:
		status.text = '⬜'
	hbox.add_child(status)

	# 情報
	var info = VBoxContainer.new()
	info.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	info.add_theme_constant_override('separation', 2)

	var name_lbl = Label.new()
	name_lbl.text = '第%d日 ｜ %s' % [mission.get('day', 0), mission.get('title', '')]
	name_lbl.add_theme_font_size_override('font_size', 14)
	name_lbl.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
	info.add_child(name_lbl)

	var cond = mission.get('condition', {})
	var param_display_name = {'study': '勉強', 'romance': '恋愛', 'friendship': '友情',
		'popularity': '人気', 'happening': 'ハプニング'}.get(cond.get('param', ''), '')
	var current = ParamStore.get_param(cond.get('param', ''))
	var target = cond.get('value', 0)
	var progress_pct = clamp(current * 100 / max(target, 1), 0, 100)

	var cond_lbl = Label.new()
	cond_lbl.text = '  %s ≥ %d　（現在 %d / %d　%d%%）' % [param_display_name, target, current, target, progress_pct]
	cond_lbl.add_theme_font_size_override('font_size', 12)
	cond_lbl.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	info.add_child(cond_lbl)

	hbox.add_child(info)

	return bg

func _update_params_row(panel: Panel) -> void:
	var params_row = panel.get_node_or_null('VBox/ParamsRow')
	if params_row == null:
		return
	for child in params_row.get_children():
		child.queue_free()

	var icons_map = {'study': '📚', 'romance': '💖', 'friendship': '🤝', 'popularity': '⭐', 'happening': '🌟'}
	var params = ParamStore.get_all_params()
	for pid in ['study', 'romance', 'friendship', 'popularity', 'happening']:
		var lbl = Label.new()
		lbl.text = '%s %d' % [icons_map[pid], params.get(pid, 0)]
		lbl.add_theme_font_size_override('font_size', 14)
		lbl.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
		params_row.add_child(lbl)

func _animate_in() -> void:
	modulate.a = 0.0
	var tween = create_tween()
	tween.tween_property(self, 'modulate:a', 1.0, 0.3)

func _on_next_day_pressed() -> void:
	visible = false
	GameManager.advance_to_next_day()
"

[node name="MissionPanel" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = SubResource("GDScript_missionpanel")
