[gd_scene load_steps=2 format=3 uid="uid://classroom_scene"]

[sub_resource type="GDScript" id="GDScript_classroom"]
script/source = "## Classroom.tscn のスクリプト
## 4×4グリッドの表示・ドラッグ&ドロップ・プレビューを管理する
extends Control

const GRID_ROWS = 4
const GRID_COLS = 4
const CELL_SIZE = 76
const GRID_OFFSET_X = 60
const GRID_OFFSET_Y = 60

# テキストカラー
const COLOR_TEXT_MAIN   = Color(0.227, 0.165, 0.102)  # #3A2A1A
const COLOR_TEXT_SUB    = Color(0.478, 0.416, 0.353)  # #7A6A5A
const COLOR_EMPTY_BG    = Color(0.980, 0.984, 0.941)
const COLOR_EMPTY_BORDER= Color(0.816, 0.847, 0.753)
const COLOR_PREVIEW_HL  = Color(0.357, 0.667, 0.863)
const COLOR_OCCUPIED_BG = Color(0.941, 0.961, 0.902)

var board: Node
var effect_engine: Node
var _cells: Array = []
var _drag_student: Dictionary = {}
var _drag_origin: int = -1

signal placement_confirmed(seat_index: int, student_data: Dictionary)

func _ready() -> void:
	_apply_dark_theme()

	board = load('res://scripts/Board.gd').new()
	board.name = 'Board'
	add_child(board)
	board.add_to_group('board')

	effect_engine = load('res://scripts/EffectEngine.gd').new()
	effect_engine.name = 'EffectEngine'
	add_child(effect_engine)

	add_to_group('classroom')

	_build_background()
	_build_grid()
	_build_param_bar()

	board.board_changed.connect(_on_board_changed)
	GameManager.student_drawn.connect(_on_student_drawn)
	ParamStore.params_changed.connect(_on_params_changed)
	ParamStore.param_preview_updated.connect(_on_param_preview_updated)

func _apply_dark_theme() -> void:
	var theme = Theme.new()
	theme.set_color('font_color', 'Label', COLOR_TEXT_MAIN)
	self.theme = theme

func _build_background() -> void:
	# ノートテクスチャ背景
	var bg = ColorRect.new()
	bg.color = Color(0.980, 0.984, 0.941)
	bg.anchor_right = 1.0
	bg.anchor_bottom = 1.0
	bg.z_index = -1
	add_child(bg)

	# 教室背景画像
	var bg_path = 'res://assets/backgrounds/classroom_bg.png'
	var bg_tex_data = _load_texture(bg_path)
	if bg_tex_data:
		var bg_tex = TextureRect.new()
		bg_tex.texture = bg_tex_data
		bg_tex.anchor_right = 1.0
		bg_tex.anchor_bottom = 1.0
		bg_tex.stretch_mode = TextureRect.STRETCH_KEEP_ASPECT_COVERED
		bg_tex.modulate.a = 0.15  # 薄く透過させてノートテクスチャ感を残す
		bg_tex.z_index = -1
		add_child(bg_tex)

func _build_grid() -> void:
	# グリッドタイトル
	var title = Label.new()
	title.text = '教室（4×4席）'
	title.position = Vector2(GRID_OFFSET_X, GRID_OFFSET_Y - 28)
	title.add_theme_font_size_override('font_size', 14)
	title.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	add_child(title)

	for i in range(GRID_ROWS * GRID_COLS):
		var row = i / GRID_COLS
		var col = i % GRID_COLS
		var cell = _create_cell(i, row, col)
		add_child(cell)
		_cells.append(cell)

func _create_cell(index: int, row: int, col: int) -> Control:
	var panel = Panel.new()
	panel.name = 'Cell_%d' % index
	panel.position = Vector2(
		GRID_OFFSET_X + col * (CELL_SIZE + 6),
		GRID_OFFSET_Y + row * (CELL_SIZE + 6)
	)
	panel.size = Vector2(CELL_SIZE, CELL_SIZE)
	panel.set_meta('seat_index', index)

	var style = StyleBoxFlat.new()
	style.bg_color = COLOR_EMPTY_BG
	style.border_color = COLOR_EMPTY_BORDER
	style.set_border_width_all(2)
	style.corner_radius_top_left = 8
	style.corner_radius_top_right = 8
	style.corner_radius_bottom_left = 8
	style.corner_radius_bottom_right = 8
	panel.add_theme_stylebox_override('panel', style)

	panel.clip_contents = true
	panel.mouse_filter = Control.MOUSE_FILTER_STOP
	panel.gui_input.connect(_on_cell_gui_input.bind(index))
	panel.mouse_entered.connect(_on_cell_hover_enter.bind(index))
	panel.mouse_exited.connect(_on_cell_hover_exit.bind(index))

	# 席番号（小さく）
	var num_label = Label.new()
	num_label.name = 'NumLabel'
	num_label.text = str(index + 1)
	num_label.position = Vector2(4, 2)
	num_label.add_theme_font_size_override('font_size', 9)
	num_label.add_theme_color_override('font_color', COLOR_EMPTY_BORDER)
	panel.add_child(num_label)

	return panel

func _build_param_bar() -> void:
	# 右側パラメータバー
	var bar_x = GRID_OFFSET_X + GRID_COLS * (CELL_SIZE + 6) + 30
	var bar_container = VBoxContainer.new()
	bar_container.name = 'ParamBarContainer'
	bar_container.position = Vector2(bar_x, GRID_OFFSET_Y)
	bar_container.size = Vector2(260, 380)
	bar_container.add_theme_constant_override('separation', 10)
	add_child(bar_container)

	# タイトル
	var bar_title = Label.new()
	bar_title.text = 'クラスの状態'
	bar_title.add_theme_font_size_override('font_size', 14)
	bar_title.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	bar_title.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	bar_container.add_child(bar_title)

	# 5パラメータバー
	var param_defs = [
		{'id': 'study',      'name': '勉強',       'icon': '📚', 'color': Color(0.290, 0.565, 0.851)},
		{'id': 'romance',    'name': '恋愛',       'icon': '💖', 'color': Color(0.910, 0.357, 0.541)},
		{'id': 'friendship', 'name': '友情',       'icon': '🤝', 'color': Color(0.357, 0.682, 0.369)},
		{'id': 'popularity', 'name': '人気',       'icon': '⭐', 'color': Color(0.961, 0.651, 0.137)},
		{'id': 'happening',  'name': 'ハプニング', 'icon': '🌟', 'color': Color(0.608, 0.349, 0.714)},
	]
	for pdef in param_defs:
		var row = _create_param_row(pdef)
		bar_container.add_child(row)

	# 現在日 + チケット表示
	var info_row = HBoxContainer.new()
	info_row.name = 'InfoRow'
	info_row.add_theme_constant_override('separation', 12)
	bar_container.add_child(info_row)

	var day_label = Label.new()
	day_label.name = 'DayLabel'
	day_label.add_theme_font_size_override('font_size', 13)
	day_label.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
	info_row.add_child(day_label)

	var ticket_label = Label.new()
	ticket_label.name = 'TicketLabel'
	ticket_label.add_theme_font_size_override('font_size', 13)
	ticket_label.add_theme_color_override('font_color', Color(0.961, 0.651, 0.137))
	info_row.add_child(ticket_label)

func _create_param_row(pdef: Dictionary) -> Control:
	var row = VBoxContainer.new()
	row.name = 'Param_' + pdef['id']
	row.add_theme_constant_override('separation', 2)

	var header_row = HBoxContainer.new()
	row.add_child(header_row)

	var icon_label = Label.new()
	icon_label.text = pdef['icon'] + ' ' + pdef['name']
	icon_label.add_theme_font_size_override('font_size', 12)
	icon_label.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
	icon_label.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	header_row.add_child(icon_label)

	var val_label = Label.new()
	val_label.name = 'Value'
	val_label.text = '0'
	val_label.add_theme_font_size_override('font_size', 12)
	val_label.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
	header_row.add_child(val_label)

	var bar_bg = Panel.new()
	bar_bg.custom_minimum_size = Vector2(0, 10)
	var bg_style = StyleBoxFlat.new()
	bg_style.bg_color = Color(0.816, 0.847, 0.753)
	bg_style.corner_radius_top_left = 5
	bg_style.corner_radius_top_right = 5
	bg_style.corner_radius_bottom_left = 5
	bg_style.corner_radius_bottom_right = 5
	bar_bg.add_theme_stylebox_override('panel', bg_style)
	bar_bg.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	row.add_child(bar_bg)

	var bar_fill = Panel.new()
	bar_fill.name = 'Fill'
	bar_fill.position = Vector2(0, 0)
	bar_fill.size = Vector2(0, 10)
	var fill_style = StyleBoxFlat.new()
	fill_style.bg_color = pdef['color']
	fill_style.corner_radius_top_left = 5
	fill_style.corner_radius_top_right = 5
	fill_style.corner_radius_bottom_left = 5
	fill_style.corner_radius_bottom_right = 5
	bar_fill.add_theme_stylebox_override('panel', fill_style)
	bar_bg.add_child(bar_fill)

	return row

func _on_student_drawn(student_data: Dictionary) -> void:
	_drag_student = student_data
	_drag_origin = -1

func _on_cell_gui_input(event: InputEvent, seat_index: int) -> void:
	if event is InputEventMouseButton:
		if event.button_index == MOUSE_BUTTON_LEFT and event.pressed:
			if not _drag_student.is_empty() and board.is_empty(seat_index):
				_confirm_placement(seat_index)

func _confirm_placement(seat_index: int) -> void:
	if _drag_student.is_empty():
		return
	# プレイヤーの席には配置不可
	if seat_index == board.player_seat:
		return
	_drag_student['_placed_day'] = GameManager.current_day
	_drag_student['_hidden_revealed'] = false

	if board.place_student(seat_index, _drag_student):
		GameManager.placed_student_ids.append(_drag_student.get('id', ''))
		placement_confirmed.emit(seat_index, _drag_student)
		_drag_student = {}
		_update_grid_display()
		GameManager.complete_placement(board)

func _on_cell_hover_enter(seat_index: int) -> void:
	if _drag_student.is_empty() or not board.is_empty(seat_index) or seat_index == board.player_seat:
		return
	# board_changed を一時切断してプレビュー計算中にスプライトが点滅しないようにする
	board.board_changed.disconnect(_on_board_changed)
	board.place_student(seat_index, _drag_student)
	var preview_deltas = effect_engine.evaluate_preview(board)
	board.remove_student(seat_index)
	board.board_changed.connect(_on_board_changed)
	ParamStore.set_preview(preview_deltas)
	_highlight_cell(seat_index, true)

func _on_cell_hover_exit(seat_index: int) -> void:
	ParamStore.clear_preview()
	_highlight_cell(seat_index, false)

func _highlight_cell(seat_index: int, highlight: bool) -> void:
	if seat_index < 0 or seat_index >= _cells.size():
		return
	var panel = _cells[seat_index]
	var style = panel.get_theme_stylebox('panel').duplicate()
	if highlight:
		style.bg_color = Color(0.357, 0.667, 0.863, 0.3)
		style.border_color = COLOR_PREVIEW_HL
		style.set_border_width_all(3)
	else:
		style.bg_color = COLOR_EMPTY_BG if board.is_empty(seat_index) else COLOR_OCCUPIED_BG
		style.border_color = COLOR_EMPTY_BORDER
		style.set_border_width_all(2)
	panel.add_theme_stylebox_override('panel', style)

func _on_board_changed() -> void:
	_update_grid_display()

func _on_params_changed(params: Dictionary) -> void:
	_update_param_bar(params)

func _on_param_preview_updated(deltas: Dictionary) -> void:
	var preview = ParamStore.get_preview_params()
	_update_param_bar(preview)

func _update_grid_display() -> void:
	for i in range(_cells.size()):
		var cell = _cells[i]
		# スプライトコンテナ以外の子をクリア
		for child in cell.get_children():
			if child.name != 'NumLabel':
				child.queue_free()

		# プレイヤーの席を専用表示
		if i == board.player_seat:
			var you_label = Label.new()
			you_label.text = GameManager.player_name if not GameManager.player_name.is_empty() else 'あなた'
			you_label.position = Vector2(0, CELL_SIZE / 2 - 8)
			you_label.size = Vector2(CELL_SIZE, 18)
			you_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
			you_label.add_theme_font_size_override('font_size', 9)
			you_label.add_theme_color_override('font_color', Color(0.290, 0.565, 0.851))
			cell.add_child(you_label)
			_set_cell_style(cell, true)
			continue

		var student = board.get_student_at(i)
		if student == null:
			_set_cell_style(cell, false)
			continue

		_set_cell_style(cell, true)

		# スプライト表示
		var sprite_id = student.get('id', '')
		var sprite_path = 'res://assets/sprites/' + sprite_id + '_48x48.png'
		var sprite_tex = _load_texture(sprite_path)
		if sprite_tex:
			var tex_rect = TextureRect.new()
			tex_rect.texture = sprite_tex
			tex_rect.size = Vector2(CELL_SIZE - 8, CELL_SIZE - 24)
			tex_rect.position = Vector2(4, 4)
			tex_rect.stretch_mode = TextureRect.STRETCH_KEEP_ASPECT_CENTERED
			tex_rect.expand_mode = TextureRect.EXPAND_IGNORE_SIZE
			cell.add_child(tex_rect)

		# 名前ラベル（スプライト下部）
		var name_lbl = Label.new()
		name_lbl.text = student.get('name', '？')
		name_lbl.position = Vector2(0, CELL_SIZE - 18)
		name_lbl.size = Vector2(CELL_SIZE, 18)
		name_lbl.add_theme_font_size_override('font_size', 9)
		name_lbl.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
		name_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
		cell.add_child(name_lbl)

func _set_cell_style(cell: Panel, occupied: bool) -> void:
	var style = cell.get_theme_stylebox('panel').duplicate()
	style.bg_color = COLOR_OCCUPIED_BG if occupied else COLOR_EMPTY_BG
	style.border_color = Color(0.357, 0.682, 0.369, 0.6) if occupied else COLOR_EMPTY_BORDER
	cell.add_theme_stylebox_override('panel', style)

func _update_param_bar(params: Dictionary) -> void:
	var container = get_node_or_null('ParamBarContainer')
	if container == null:
		return

	var day_label = container.get_node_or_null('InfoRow/DayLabel')
	if day_label:
		day_label.text = '%d日目 / 30日' % GameManager.current_day

	var ticket_label = container.get_node_or_null('InfoRow/TicketLabel')
	if ticket_label:
		ticket_label.text = '🎫×%d' % GameManager.swap_tickets

	for param_id in ['study', 'romance', 'friendship', 'popularity', 'happening']:
		var row = container.get_node_or_null('Param_' + param_id)
		if row == null:
			continue
		var val = params.get(param_id, 0)
		var val_label = row.get_node_or_null('HBoxContainer/Value')
		if val_label:
			val_label.text = str(val)
		var fill = row.get_node_or_null('Panel/Fill')
		if fill:
			var bar_width = row.get_node_or_null('Panel').size.x
			fill.size.x = bar_width * val / 100.0

func _load_texture(res_path: String) -> Texture2D:
	var abs_path = ProjectSettings.globalize_path(res_path)
	var img = Image.new()
	if img.load(abs_path) == OK:
		return ImageTexture.create_from_image(img)
	return null
"

[node name="Classroom" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = SubResource("GDScript_classroom")
