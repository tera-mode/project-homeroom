[gd_scene load_steps=2 format=3 uid="uid://classroom_scene"]

[sub_resource type="GDScript" id="GDScript_classroom"]
script/source = "## Classroom.tscn のスクリプト
## 4×4グリッドの表示・配置・授業フェーズUIを管理する
extends Control

const GRID_ROWS = 4
const GRID_COLS = 4
const CELL_SIZE = 76

const GRID_OFFSET_X = 60
const GRID_OFFSET_Y = 60

const COLOR_TEXT_MAIN    = Color(0.227, 0.165, 0.102)
const COLOR_TEXT_SUB     = Color(0.478, 0.416, 0.353)
const COLOR_EMPTY_BG     = Color(0.980, 0.984, 0.941)
const COLOR_EMPTY_BORDER = Color(0.816, 0.847, 0.753)
const COLOR_PREVIEW_HL   = Color(0.357, 0.667, 0.863)
const COLOR_OCCUPIED_BG  = Color(0.941, 0.961, 0.902)

const TYPE_ICONS = { \"yancha\": \"🔥\", \"yuutousei\": \"📖\", \"otaku\": \"🎮\", \"futsu\": \"😊\" }

var board: Node
var _cells: Array = []
var _drag_student: Dictionary = {}
var _class_overlay: Control = null

signal placement_confirmed(seat_index: int, student_data: Dictionary)

func _ready() -> void:
	_apply_dark_theme()
	board = load('res://scripts/Board.gd').new()
	board.name = 'Board'
	add_child(board)
	board.add_to_group('board')
	add_to_group('classroom')
	_build_background()
	_build_grid()
	_build_info_panel()
	_build_class_overlay()
	board.board_changed.connect(_on_board_changed)
	GameManager.student_drawn.connect(_on_student_drawn)
	GameManager.phase_changed.connect(_on_phase_changed)

func _apply_dark_theme() -> void:
	var theme = Theme.new()
	theme.set_color('font_color', 'Label', COLOR_TEXT_MAIN)
	self.theme = theme

func _build_background() -> void:
	var bg = ColorRect.new()
	bg.color = Color(0.980, 0.984, 0.941)
	bg.anchor_right = 1.0
	bg.anchor_bottom = 1.0
	bg.z_index = -1
	add_child(bg)
	var bg_path = 'res://assets/backgrounds/classroom_bg.png'
	var bg_tex_data = _load_texture(bg_path)
	if bg_tex_data:
		var bg_tex = TextureRect.new()
		bg_tex.texture = bg_tex_data
		bg_tex.anchor_right = 1.0
		bg_tex.anchor_bottom = 1.0
		bg_tex.stretch_mode = TextureRect.STRETCH_KEEP_ASPECT_COVERED
		bg_tex.modulate.a = 0.15
		bg_tex.z_index = -1
		add_child(bg_tex)

func _build_grid() -> void:
	var title = Label.new()
	title.text = '教室（4×4席）'
	title.position = Vector2(GRID_OFFSET_X, GRID_OFFSET_Y - 28)
	title.add_theme_font_size_override('font_size', 14)
	title.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	add_child(title)
	for i in range(GRID_ROWS * GRID_COLS):
		var cell = _create_cell(i, i / GRID_COLS, i % GRID_COLS)
		add_child(cell)
		_cells.append(cell)

func _create_cell(index: int, row: int, col: int) -> Control:
	var panel = Panel.new()
	panel.name = 'Cell_%d' % index
	panel.position = Vector2(GRID_OFFSET_X + col * (CELL_SIZE + 6), GRID_OFFSET_Y + row * (CELL_SIZE + 6))
	panel.size = Vector2(CELL_SIZE, CELL_SIZE)
	panel.set_meta('seat_index', index)
	var style = StyleBoxFlat.new()
	style.bg_color = COLOR_EMPTY_BG
	style.border_color = COLOR_EMPTY_BORDER
	style.set_border_width_all(2)
	style.corner_radius_top_left = 8
	style.corner_radius_top_right = 8
	style.corner_radius_bottom_left = 8
	style.corner_radius_bottom_right = 8
	panel.add_theme_stylebox_override('panel', style)
	panel.clip_contents = true
	panel.mouse_filter = Control.MOUSE_FILTER_STOP
	panel.gui_input.connect(_on_cell_gui_input.bind(index))
	panel.mouse_entered.connect(_on_cell_hover_enter.bind(index))
	panel.mouse_exited.connect(_on_cell_hover_exit.bind(index))
	var num_label = Label.new()
	num_label.name = 'NumLabel'
	num_label.text = str(index + 1)
	num_label.position = Vector2(4, 2)
	num_label.add_theme_font_size_override('font_size', 9)
	num_label.add_theme_color_override('font_color', COLOR_EMPTY_BORDER)
	panel.add_child(num_label)
	return panel

func _build_info_panel() -> void:
	var bar_x = GRID_OFFSET_X + GRID_COLS * (CELL_SIZE + 6) + 30
	var panel = VBoxContainer.new()
	panel.name = 'InfoPanel'
	panel.position = Vector2(bar_x, GRID_OFFSET_Y)
	panel.size = Vector2(230, 300)
	panel.add_theme_constant_override('separation', 14)
	add_child(panel)

	var title = Label.new()
	title.text = 'クラス情報'
	title.add_theme_font_size_override('font_size', 14)
	title.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	title.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	panel.add_child(title)

	var day_lbl = Label.new()
	day_lbl.name = 'DayLabel'
	day_lbl.add_theme_font_size_override('font_size', 18)
	day_lbl.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
	day_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	panel.add_child(day_lbl)

	var test_lbl = Label.new()
	test_lbl.name = 'TestLabel'
	test_lbl.add_theme_font_size_override('font_size', 13)
	test_lbl.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	test_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	panel.add_child(test_lbl)

	var placed_lbl = Label.new()
	placed_lbl.name = 'PlacedLabel'
	placed_lbl.add_theme_font_size_override('font_size', 12)
	placed_lbl.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	placed_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	panel.add_child(placed_lbl)

func _build_class_overlay() -> void:
	# CLASS_PHASE に表示するオーバーレイ
	_class_overlay = Panel.new()
	_class_overlay.name = 'ClassOverlay'
	_class_overlay.anchor_left   = 0.5
	_class_overlay.anchor_top    = 0.5
	_class_overlay.anchor_right  = 0.5
	_class_overlay.anchor_bottom = 0.5
	_class_overlay.offset_left   = -200
	_class_overlay.offset_right  = 200
	_class_overlay.offset_top    = -110
	_class_overlay.offset_bottom = 110
	var style = StyleBoxFlat.new()
	style.bg_color = Color(0.12, 0.14, 0.22, 0.95)
	style.corner_radius_top_left = 14
	style.corner_radius_top_right = 14
	style.corner_radius_bottom_left = 14
	style.corner_radius_bottom_right = 14
	style.set_border_width_all(2)
	style.border_color = Color(0.4, 0.5, 0.8, 0.5)
	_class_overlay.add_theme_stylebox_override('panel', style)
	_class_overlay.visible = false
	add_child(_class_overlay)

	var margin = MarginContainer.new()
	margin.anchor_right = 1.0
	margin.anchor_bottom = 1.0
	margin.add_theme_constant_override('margin_left', 24)
	margin.add_theme_constant_override('margin_right', 24)
	margin.add_theme_constant_override('margin_top', 18)
	margin.add_theme_constant_override('margin_bottom', 18)
	_class_overlay.add_child(margin)

	var vbox = VBoxContainer.new()
	vbox.add_theme_constant_override('separation', 14)
	margin.add_child(vbox)

	var subject_title = Label.new()
	subject_title.name = 'SubjectTitle'
	subject_title.text = '今日の授業'
	subject_title.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	subject_title.add_theme_font_size_override('font_size', 14)
	subject_title.add_theme_color_override('font_color', Color(0.65, 0.70, 0.80))
	vbox.add_child(subject_title)

	var subject_lbl = Label.new()
	subject_lbl.name = 'SubjectLabel'
	subject_lbl.text = '📚 勉強'
	subject_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	subject_lbl.add_theme_font_size_override('font_size', 28)
	subject_lbl.add_theme_color_override('font_color', Color.WHITE)
	vbox.add_child(subject_lbl)

	var test_badge = Label.new()
	test_badge.name = 'TestBadge'
	test_badge.text = ''
	test_badge.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	test_badge.add_theme_font_size_override('font_size', 14)
	test_badge.add_theme_color_override('font_color', Color(1.0, 0.8, 0.2))
	vbox.add_child(test_badge)

	var advance_btn = Button.new()
	advance_btn.name = 'AdvanceBtn'
	advance_btn.text = '授業開始！'
	advance_btn.add_theme_font_size_override('font_size', 16)
	var btn_style = StyleBoxFlat.new()
	btn_style.bg_color = Color(0.290, 0.565, 0.851)
	btn_style.corner_radius_top_left = 10
	btn_style.corner_radius_top_right = 10
	btn_style.corner_radius_bottom_left = 10
	btn_style.corner_radius_bottom_right = 10
	advance_btn.add_theme_stylebox_override('normal', btn_style)
	advance_btn.add_theme_color_override('font_color', Color.WHITE)
	advance_btn.pressed.connect(_on_advance_lesson_pressed)
	vbox.add_child(advance_btn)

func _on_phase_changed(phase: GameManager.Phase) -> void:
	visible = (phase == GameManager.Phase.START_PHASE or phase == GameManager.Phase.CLASS_PHASE)
	if _class_overlay:
		_class_overlay.visible = (phase == GameManager.Phase.CLASS_PHASE)
	if phase == GameManager.Phase.CLASS_PHASE:
		_refresh_class_overlay()
	_update_info_panel()

func _refresh_class_overlay() -> void:
	if _class_overlay == null:
		return
	var subject = GameManager.today_student.get('_subject', '')
	var subject_map = { 'study': '📚 勉強', 'sports': '⚽ 運動', 'art': '🎨 芸術' }
	var subject_lbl = _class_overlay.get_node_or_null('MarginContainer/VBoxContainer/SubjectLabel')
	if subject_lbl:
		subject_lbl.text = subject_map.get(GameManager.last_day_result.get('subject', 'study'), '📚 勉強')

	var is_test = LessonManager.is_test_day(GameManager.current_day)
	var test_badge = _class_overlay.get_node_or_null('MarginContainer/VBoxContainer/TestBadge')
	if test_badge:
		test_badge.text = '📝 今日はテスト！' if is_test else ''

	# subject を last_day_result が空の場合は先取りして pick する
	if subject_lbl:
		var picked = LessonManager.pick_subject()
		subject_lbl.text = subject_map.get(picked, '📚 勉強')

func _on_student_drawn(student_data: Dictionary) -> void:
	_drag_student = student_data

func _on_cell_gui_input(event: InputEvent, seat_index: int) -> void:
	if GameManager.current_phase != GameManager.Phase.START_PHASE:
		return
	if event is InputEventMouseButton:
		if event.button_index == MOUSE_BUTTON_LEFT and event.pressed:
			if not _drag_student.is_empty() and board.is_empty(seat_index):
				_confirm_placement(seat_index)

func _confirm_placement(seat_index: int) -> void:
	if _drag_student.is_empty():
		return
	if seat_index == board.player_seat:
		return
	if board.place_student(seat_index, _drag_student):
		placement_confirmed.emit(seat_index, _drag_student)
		_drag_student = {}
		_update_grid_display()
		GameManager.go_to_class_phase(board, true)

func _on_cell_hover_enter(seat_index: int) -> void:
	if _drag_student.is_empty() or not board.is_empty(seat_index) or seat_index == board.player_seat:
		return
	_highlight_cell(seat_index, true)

func _on_cell_hover_exit(seat_index: int) -> void:
	_highlight_cell(seat_index, false)

func _highlight_cell(seat_index: int, highlight: bool) -> void:
	if seat_index < 0 or seat_index >= _cells.size():
		return
	var panel = _cells[seat_index]
	var style = panel.get_theme_stylebox('panel').duplicate()
	if highlight:
		style.bg_color = Color(0.357, 0.667, 0.863, 0.3)
		style.border_color = COLOR_PREVIEW_HL
		style.set_border_width_all(3)
	else:
		style.bg_color = COLOR_EMPTY_BG if board.is_empty(seat_index) else COLOR_OCCUPIED_BG
		style.border_color = COLOR_EMPTY_BORDER
		style.set_border_width_all(2)
	panel.add_theme_stylebox_override('panel', style)

func _on_advance_lesson_pressed() -> void:
	GameManager.advance_day(board)

func _on_board_changed() -> void:
	_update_grid_display()
	_update_info_panel()

func _update_info_panel() -> void:
	var panel = get_node_or_null('InfoPanel')
	if panel == null:
		return
	var day_lbl = panel.get_node_or_null('DayLabel')
	if day_lbl:
		day_lbl.text = '📅 %d日目 / 30日' % GameManager.current_day
	var test_lbl = panel.get_node_or_null('TestLabel')
	if test_lbl:
		var next_test = _days_to_next_test()
		if next_test == 0:
			test_lbl.text = '📝 今日はテスト！'
		elif next_test > 0:
			test_lbl.text = 'テストまで %d日' % next_test
		else:
			test_lbl.text = '全テスト終了'
	var placed_lbl = panel.get_node_or_null('PlacedLabel')
	if placed_lbl:
		var count = board.get_all_placed().size()
		placed_lbl.text = '在席: %d / 15名' % count

func _days_to_next_test() -> int:
	var day = GameManager.current_day
	for test_day in LessonManager.TEST_DAYS:
		if test_day >= day:
			return test_day - day
	return -1

func _update_grid_display() -> void:
	for i in range(_cells.size()):
		var cell = _cells[i]
		for child in cell.get_children():
			if child.name != 'NumLabel':
				child.queue_free()

		# プレイヤー席
		if i == board.player_seat:
			var lbl = Label.new()
			lbl.text = GameManager.player_name if not GameManager.player_name.is_empty() else 'あなた'
			lbl.position = Vector2(0, CELL_SIZE / 2 - 8)
			lbl.size = Vector2(CELL_SIZE, 18)
			lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
			lbl.add_theme_font_size_override('font_size', 9)
			lbl.add_theme_color_override('font_color', Color(0.290, 0.565, 0.851))
			cell.add_child(lbl)
			_set_cell_style(cell, true)
			continue

		var student = board.get_student_at(i)
		if student == null:
			_set_cell_style(cell, false)
			continue
		_set_cell_style(cell, true)

		# タイプアイコン（左上）
		var char_id = student.get('id', '')
		var state = CharacterState.get_state(char_id)
		var char_type = state.get('type', student.get('type', ''))
		if char_type != '':
			var type_lbl = Label.new()
			type_lbl.text = TYPE_ICONS.get(char_type, '')
			type_lbl.position = Vector2(2, 14)
			type_lbl.add_theme_font_size_override('font_size', 10)
			cell.add_child(type_lbl)

		# スプライト
		var sprite_path = 'res://assets/sprites/' + char_id + '_48x48.png'
		var sprite_tex = _load_texture(sprite_path)
		if sprite_tex:
			var tex_rect = TextureRect.new()
			tex_rect.texture = sprite_tex
			tex_rect.size = Vector2(CELL_SIZE - 8, CELL_SIZE - 28)
			tex_rect.position = Vector2(4, 4)
			tex_rect.stretch_mode = TextureRect.STRETCH_KEEP_ASPECT_CENTERED
			tex_rect.expand_mode = TextureRect.EXPAND_IGNORE_SIZE
			cell.add_child(tex_rect)

		# 名前
		var name_lbl = Label.new()
		name_lbl.text = student.get('name', '？')
		name_lbl.position = Vector2(0, CELL_SIZE - 22)
		name_lbl.size = Vector2(CELL_SIZE, 14)
		name_lbl.add_theme_font_size_override('font_size', 8)
		name_lbl.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
		name_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
		cell.add_child(name_lbl)

		# 充実度バー（下部4px）
		var fulfillment = state.get('fulfillment', 0)
		var bar_bg = ColorRect.new()
		bar_bg.color = Color(0.3, 0.3, 0.3, 0.5)
		bar_bg.size = Vector2(CELL_SIZE, 4)
		bar_bg.position = Vector2(0, CELL_SIZE - 4)
		cell.add_child(bar_bg)
		var f_ratio = clampf((fulfillment + 20.0) / 50.0, 0.0, 1.0)
		var bar_fill = ColorRect.new()
		bar_fill.color = Color(0.2, 0.8, 0.4) if fulfillment >= 0 else Color(0.8, 0.2, 0.2)
		bar_fill.size = Vector2(CELL_SIZE * f_ratio, 4)
		bar_fill.position = Vector2(0, CELL_SIZE - 4)
		cell.add_child(bar_fill)

func _set_cell_style(cell: Panel, occupied: bool) -> void:
	var style = cell.get_theme_stylebox('panel').duplicate()
	style.bg_color = COLOR_OCCUPIED_BG if occupied else COLOR_EMPTY_BG
	style.border_color = Color(0.357, 0.682, 0.369, 0.6) if occupied else COLOR_EMPTY_BORDER
	cell.add_theme_stylebox_override('panel', style)

func _load_texture(res_path: String) -> Texture2D:
	var abs_path = ProjectSettings.globalize_path(res_path)
	var img = Image.new()
	if img.load(abs_path) == OK:
		return ImageTexture.create_from_image(img)
	return null
"

[node name="Classroom" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = SubResource("GDScript_classroom")
