[gd_scene load_steps=2 format=3 uid="uid://ending_screen_scene"]

[sub_resource type="GDScript" id="GDScript_ending"]
script/source = "## EndingScreen.tscn のスクリプト
## エンディング表示。充実度ベースの4種エンディング。
extends Control

const ENDINGS = {
	'true_ending': {
		'title': '★★ 輝かしい学園生活',
		'text': 'クラスのみんなと本当の絆を結べた。\\n卒業式、教室中に笑顔があふれた。\\nあの30日間は、一生の宝物になった。',
		'color': Color(1.0, 0.84, 0.0),
		'bg_color': Color(0.08, 0.05, 0.18)
	},
	'normal_ending': {
		'title': '★ 楽しい学園生活',
		'text': 'たくさんの友達ができた。\\n毎日がにぎやかで、あっという間だった。\\n「また会おうね」そう言って卒業した。',
		'color': Color(0.4, 0.8, 1.0),
		'bg_color': Color(0.05, 0.08, 0.18)
	},
	'plain_ending': {
		'title': 'ふつうの学園生活',
		'text': '可もなく不可もない30日だった。\\n特別なことは何も起きなかったけど、\\nそれはそれで、悪くなかったかもしれない。',
		'color': Color(0.7, 0.75, 0.85),
		'bg_color': Color(0.08, 0.08, 0.12)
	},
	'bad_ending': {
		'title': 'つらい学園生活',
		'text': 'うまくいかないことばかりだった。\\n卒業式、教室はしんとしていた。\\n「やり直せたら……」そう思いながら帰った。',
		'color': Color(0.6, 0.3, 0.3),
		'bg_color': Color(0.08, 0.05, 0.05)
	}
}

var _current_ending: String = ''

func _ready() -> void:
	GameManager.ending_reached.connect(_on_ending_reached)
	_build_ui()

func _build_ui() -> void:
	var bg = ColorRect.new()
	bg.name = 'Background'
	bg.anchor_right = 1.0
	bg.anchor_bottom = 1.0
	bg.color = Color(0.05, 0.05, 0.1)
	add_child(bg)

	var vbox = VBoxContainer.new()
	vbox.name = 'Content'
	vbox.anchor_left = 0.1
	vbox.anchor_top = 0.08
	vbox.anchor_right = 0.9
	vbox.anchor_bottom = 0.92
	vbox.add_theme_constant_override('separation', 20)
	add_child(vbox)

	var title = Label.new()
	title.name = 'Title'
	title.add_theme_font_size_override('font_size', 36)
	title.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	vbox.add_child(title)

	var sep = HSeparator.new()
	vbox.add_child(sep)

	var text = RichTextLabel.new()
	text.name = 'EndingText'
	text.add_theme_font_size_override('normal_font_size', 18)
	text.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	text.size_flags_vertical = Control.SIZE_EXPAND_FILL
	text.bbcode_enabled = true
	text.autowrap_mode = TextServer.AUTOWRAP_WORD
	vbox.add_child(text)

	var fulfillment_lbl = Label.new()
	fulfillment_lbl.name = 'FulfillmentLabel'
	fulfillment_lbl.add_theme_font_size_override('font_size', 16)
	fulfillment_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	fulfillment_lbl.add_theme_color_override('font_color', Color.WHITE)
	vbox.add_child(fulfillment_lbl)

	var btn_row = HBoxContainer.new()
	btn_row.alignment = BoxContainer.ALIGNMENT_CENTER
	btn_row.add_theme_constant_override('separation', 20)
	vbox.add_child(btn_row)

	var title_btn = Button.new()
	title_btn.text = 'タイトルに戻る'
	title_btn.add_theme_font_size_override('font_size', 16)
	title_btn.pressed.connect(_on_title_pressed)
	btn_row.add_child(title_btn)

func _on_ending_reached(ending_id: String) -> void:
	_current_ending = ending_id
	visible = true
	_show_ending(ending_id)
	_animate_in()

func _show_ending(ending_id: String) -> void:
	var data = ENDINGS.get(ending_id, ENDINGS['plain_ending'])
	var bg = get_node_or_null('Background')
	if bg:
		bg.color = data['bg_color']
	var title = get_node_or_null('Content/Title')
	if title:
		title.text = data['title']
		title.add_theme_color_override('font_color', data['color'])
	var text = get_node_or_null('Content/EndingText')
	if text:
		text.text = data['text']
		text.add_theme_color_override('default_color', Color.WHITE)
	var f_lbl = get_node_or_null('Content/FulfillmentLabel')
	if f_lbl:
		var fulfillment = CharacterState.get_state('player').get('fulfillment', 0)
		f_lbl.text = '最終充実度: %d' % fulfillment

func _animate_in() -> void:
	modulate.a = 0.0
	var tween = create_tween()
	tween.tween_property(self, 'modulate:a', 1.0, 1.0)

func _on_title_pressed() -> void:
	visible = false
	GameManager.reset_to_title()
"

[node name="EndingScreen" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = SubResource("GDScript_ending")
