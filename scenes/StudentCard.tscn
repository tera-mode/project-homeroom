[gd_scene load_steps=2 format=3 uid="uid://student_card_scene"]

[sub_resource type="GDScript" id="GDScript_studentcard"]
script/source = "## StudentCard.tscn のスクリプト
## 転校生情報カード（v2.0）: タイプ / 好き嫌い / 能力3種 / 特殊能力 / ヒント
extends Control

const CARD_WIDTH  = 300
const CARD_HEIGHT = 440

const RARITY_COLORS = {
	1: Color(0.753, 0.753, 0.753),
	2: Color(0.957, 0.784, 0.267),
	3: Color(0.5, 0.2, 1.0)
}
const TYPE_ICONS = { 'yancha': '🔥', 'yuutousei': '📖', 'otaku': '🎮', 'futsu': '😊' }
const TYPE_NAMES = { 'yancha': 'ヤンチャ', 'yuutousei': 'ゆうとうせい', 'otaku': 'オタク', 'futsu': 'ふつう' }

const COLOR_TEXT_MAIN = Color(0.227, 0.165, 0.102)
const COLOR_TEXT_SUB  = Color(0.478, 0.416, 0.353)

var _current_student: Dictionary = {}
var _sprite_node: TextureRect = null

func _ready() -> void:
	_apply_dark_theme()
	GameManager.student_drawn.connect(_on_student_drawn)
	GameManager.phase_changed.connect(_on_phase_changed)
	_build_card_ui()

func _apply_dark_theme() -> void:
	var theme = Theme.new()
	theme.set_color('font_color', 'Label', COLOR_TEXT_MAIN)
	self.theme = theme

func _build_card_ui() -> void:
	custom_minimum_size = Vector2(CARD_WIDTH, CARD_HEIGHT)
	anchor_left = 0.5
	anchor_top = 0.5
	anchor_right = 0.5
	anchor_bottom = 0.5
	offset_left   = -CARD_WIDTH / 2
	offset_top    = -CARD_HEIGHT / 2
	offset_right  = CARD_WIDTH / 2
	offset_bottom = CARD_HEIGHT / 2

	var panel = Panel.new()
	panel.name = 'CardPanel'
	panel.size = Vector2(CARD_WIDTH, CARD_HEIGHT)
	var style = StyleBoxFlat.new()
	style.bg_color = Color(0.980, 0.984, 0.941)
	style.set_border_width_all(4)
	style.border_color = RARITY_COLORS[1]
	style.corner_radius_top_left = 14
	style.corner_radius_top_right = 14
	style.corner_radius_bottom_left = 14
	style.corner_radius_bottom_right = 14
	style.shadow_color = Color(0, 0, 0, 0.2)
	style.shadow_size = 6
	panel.add_theme_stylebox_override('panel', style)
	add_child(panel)

	var vbox = VBoxContainer.new()
	vbox.name = 'Content'
	vbox.position = Vector2(16, 12)
	vbox.size = Vector2(CARD_WIDTH - 32, CARD_HEIGHT - 24)
	vbox.add_theme_constant_override('separation', 6)
	panel.add_child(vbox)

	# レア度 + タイプ
	var header = HBoxContainer.new()
	vbox.add_child(header)

	var rarity_lbl = Label.new()
	rarity_lbl.name = 'RarityLabel'
	rarity_lbl.add_theme_font_size_override('font_size', 16)
	rarity_lbl.add_theme_color_override('font_color', Color(0.957, 0.784, 0.267))
	header.add_child(rarity_lbl)

	var type_lbl = Label.new()
	type_lbl.name = 'TypeLabel'
	type_lbl.add_theme_font_size_override('font_size', 12)
	type_lbl.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	type_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_RIGHT
	type_lbl.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	header.add_child(type_lbl)

	# スプライト
	var sprite_container = CenterContainer.new()
	sprite_container.custom_minimum_size = Vector2(0, 120)
	vbox.add_child(sprite_container)

	var sprite = TextureRect.new()
	sprite.name = 'Sprite'
	sprite.custom_minimum_size = Vector2(100, 100)
	sprite.expand_mode = TextureRect.EXPAND_IGNORE_SIZE
	sprite.stretch_mode = TextureRect.STRETCH_KEEP_ASPECT_CENTERED
	sprite_container.add_child(sprite)
	_sprite_node = sprite

	# 名前
	var name_lbl = Label.new()
	name_lbl.name = 'NameLabel'
	name_lbl.add_theme_font_size_override('font_size', 20)
	name_lbl.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
	name_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	vbox.add_child(name_lbl)

	# 好き/嫌いタイプ
	var like_row = HBoxContainer.new()
	like_row.alignment = BoxContainer.ALIGNMENT_CENTER
	like_row.add_theme_constant_override('separation', 12)
	vbox.add_child(like_row)

	var like_lbl = Label.new()
	like_lbl.name = 'LikeLabel'
	like_lbl.add_theme_font_size_override('font_size', 12)
	like_lbl.add_theme_color_override('font_color', Color(0.2, 0.65, 0.3))
	like_row.add_child(like_lbl)

	var dislike_lbl = Label.new()
	dislike_lbl.name = 'DislikeLabel'
	dislike_lbl.add_theme_font_size_override('font_size', 12)
	dislike_lbl.add_theme_color_override('font_color', Color(0.8, 0.2, 0.2))
	like_row.add_child(dislike_lbl)

	# 能力3種
	var stats_row = HBoxContainer.new()
	stats_row.name = 'StatsRow'
	stats_row.alignment = BoxContainer.ALIGNMENT_CENTER
	stats_row.add_theme_constant_override('separation', 14)
	vbox.add_child(stats_row)
	for stat_id in ['study', 'sports', 'art']:
		var stat_lbl = Label.new()
		stat_lbl.name = 'Stat_' + stat_id
		stat_lbl.add_theme_font_size_override('font_size', 12)
		stat_lbl.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
		stats_row.add_child(stat_lbl)

	# 特殊能力
	var ability_lbl = Label.new()
	ability_lbl.name = 'AbilityLabel'
	ability_lbl.add_theme_font_size_override('font_size', 11)
	ability_lbl.add_theme_color_override('font_color', Color(0.4, 0.3, 0.6))
	ability_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	ability_lbl.autowrap_mode = TextServer.AUTOWRAP_WORD
	vbox.add_child(ability_lbl)

	var sep = HSeparator.new()
	vbox.add_child(sep)

	# ヒント
	var hint_lbl = Label.new()
	hint_lbl.name = 'HintLabel'
	hint_lbl.add_theme_font_size_override('font_size', 11)
	hint_lbl.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	hint_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	hint_lbl.autowrap_mode = TextServer.AUTOWRAP_WORD
	vbox.add_child(hint_lbl)

	# 配置ボタン
	var btn = Button.new()
	btn.name = 'PlaceButton'
	btn.text = '席に座らせる →'
	btn.add_theme_font_size_override('font_size', 14)
	var btn_style = StyleBoxFlat.new()
	btn_style.bg_color = Color(0.290, 0.565, 0.851)
	btn_style.corner_radius_top_left = 8
	btn_style.corner_radius_top_right = 8
	btn_style.corner_radius_bottom_left = 8
	btn_style.corner_radius_bottom_right = 8
	btn.add_theme_stylebox_override('normal', btn_style)
	btn.add_theme_color_override('font_color', Color.WHITE)
	btn.pressed.connect(_on_place_button_pressed)
	vbox.add_child(btn)

func _on_student_drawn(student_data: Dictionary) -> void:
	_current_student = student_data
	_update_card_display()
	_animate_in()

func _update_card_display() -> void:
	if _current_student.is_empty():
		return
	var content = get_node_or_null('CardPanel/Content')
	if content == null:
		return

	var rarity = _current_student.get('rarity', 1)
	var rarity_lbl = content.get_node_or_null('Header/RarityLabel')
	if rarity_lbl:
		rarity_lbl.text = '★'.repeat(rarity)

	var s_type = _current_student.get('type', 'futsu')
	var type_lbl = content.get_node_or_null('Header/TypeLabel')
	if type_lbl:
		type_lbl.text = TYPE_ICONS.get(s_type, '') + ' ' + TYPE_NAMES.get(s_type, s_type)

	if _sprite_node:
		var sprite_path = 'res://assets/sprites/' + _current_student.get('id', '') + '_48x48.png'
		_sprite_node.texture = _load_texture(sprite_path)

	var name_lbl = content.get_node_or_null('NameLabel')
	if name_lbl:
		name_lbl.text = _current_student.get('name', '？')

	var like_t    = _current_student.get('like_type', '')
	var dislike_t = _current_student.get('dislike_type', '')
	var like_lbl = content.get_node_or_null('HBoxContainer/LikeLabel')
	if like_lbl:
		like_lbl.text = '💚 好き: ' + TYPE_NAMES.get(like_t, like_t) if like_t != '' else ''
	var dislike_lbl = content.get_node_or_null('HBoxContainer/DislikeLabel')
	if dislike_lbl:
		dislike_lbl.text = '❌ 苦手: ' + TYPE_NAMES.get(dislike_t, dislike_t) if dislike_t != '' else ''

	var stat_icons = { 'study': '📚', 'sports': '⚽', 'art': '🎨' }
	var stats_row = content.get_node_or_null('StatsRow')
	if stats_row:
		for stat_id in ['study', 'sports', 'art']:
			var stat_lbl = stats_row.get_node_or_null('Stat_' + stat_id)
			if stat_lbl:
				var val = _current_student.get('initial_' + stat_id, 0)
				stat_lbl.text = '%s %d' % [stat_icons.get(stat_id, ''), val]

	var abilities = _current_student.get('abilities', [])
	var ability_lbl = content.get_node_or_null('AbilityLabel')
	if ability_lbl and not abilities.is_empty():
		var ab_id = abilities[0]
		var ab_data = AbilityEngine._ability_map.get(ab_id, {})
		if ab_data.is_empty():
			ability_lbl.text = '特殊能力: ' + ab_id
		else:
			ability_lbl.text = ab_data.get('icon', '') + ' ' + ab_data.get('name', ab_id) + '\\n' + ab_data.get('description', '')
	elif ability_lbl:
		ability_lbl.text = ''

	var hint_lbl = content.get_node_or_null('HintLabel')
	if hint_lbl:
		hint_lbl.text = '「%s」' % _current_student.get('hint_text', '')

	var panel = get_node_or_null('CardPanel')
	if panel:
		var s = panel.get_theme_stylebox('panel').duplicate()
		s.border_color = RARITY_COLORS.get(rarity, RARITY_COLORS[1])
		panel.add_theme_stylebox_override('panel', s)

func _animate_in() -> void:
	modulate.a = 0.0
	var saved_y = position.y
	position.y += 60
	var tween = create_tween()
	tween.tween_property(self, 'position:y', saved_y, 0.3).set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_BACK)
	tween.parallel().tween_property(self, 'modulate:a', 1.0, 0.25)

func _on_place_button_pressed() -> void:
	# カードを隠す → Classroom でクリックして配置
	visible = false

func _on_phase_changed(phase: GameManager.Phase) -> void:
	visible = (phase == GameManager.Phase.START_PHASE)

func _load_texture(res_path: String) -> Texture2D:
	var abs_path = ProjectSettings.globalize_path(res_path)
	var img = Image.new()
	if img.load(abs_path) == OK:
		return ImageTexture.create_from_image(img)
	return null
"

[node name="StudentCard" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = SubResource("GDScript_studentcard")
