[gd_scene load_steps=2 format=3 uid="uid://student_card_scene"]

[sub_resource type="GDScript" id="GDScript_studentcard"]
script/source = "## StudentCard.tscn のスクリプト
## 転校生情報カード。DESIGN_POLICY §3 のガチャカードデザイン準拠。
extends Control

const CARD_WIDTH = 300
const CARD_HEIGHT = 400

const RARITY_COLORS = {
	1: Color(0.753, 0.753, 0.753),
	2: Color(0.957, 0.784, 0.267),
	3: Color(0.5, 0.2, 1.0)
}

const PARAM_ICONS = {
	'study': '📚', 'romance': '💖', 'friendship': '🤝',
	'popularity': '⭐', 'happening': '🌟'
}

# テキストカラー（DESIGN_POLICY）
const COLOR_TEXT_MAIN = Color(0.227, 0.165, 0.102)   # #3A2A1A
const COLOR_TEXT_SUB  = Color(0.478, 0.416, 0.353)   # #7A6A5A

var _current_student: Dictionary = {}
var _sprite_node: TextureRect = null

func _ready() -> void:
	_apply_dark_theme()
	GameManager.student_drawn.connect(_on_student_drawn)
	GameManager.phase_changed.connect(_on_phase_changed)
	_build_card_ui()

func _apply_dark_theme() -> void:
	var theme = Theme.new()
	theme.set_color('font_color', 'Label', COLOR_TEXT_MAIN)
	theme.set_color('default_color', 'RichTextLabel', COLOR_TEXT_MAIN)
	self.theme = theme

func _build_card_ui() -> void:
	custom_minimum_size = Vector2(CARD_WIDTH, CARD_HEIGHT)
	anchor_left = 0.5
	anchor_top = 0.5
	anchor_right = 0.5
	anchor_bottom = 0.5
	offset_left = -CARD_WIDTH / 2
	offset_top = -CARD_HEIGHT / 2
	offset_right = CARD_WIDTH / 2
	offset_bottom = CARD_HEIGHT / 2

	var panel = Panel.new()
	panel.name = 'CardPanel'
	panel.size = Vector2(CARD_WIDTH, CARD_HEIGHT)
	var style = StyleBoxFlat.new()
	style.bg_color = Color(0.980, 0.984, 0.941)
	style.set_border_width_all(4)
	style.border_color = RARITY_COLORS[1]
	style.corner_radius_top_left = 14
	style.corner_radius_top_right = 14
	style.corner_radius_bottom_left = 14
	style.corner_radius_bottom_right = 14
	style.shadow_color = Color(0, 0, 0, 0.2)
	style.shadow_size = 6
	panel.add_theme_stylebox_override('panel', style)
	add_child(panel)

	var vbox = VBoxContainer.new()
	vbox.name = 'Content'
	vbox.position = Vector2(16, 16)
	vbox.size = Vector2(CARD_WIDTH - 32, CARD_HEIGHT - 32)
	vbox.add_theme_constant_override('separation', 8)
	panel.add_child(vbox)

	# レア度 + カテゴリ
	var header = HBoxContainer.new()
	header.name = 'Header'
	vbox.add_child(header)

	var rarity_label = Label.new()
	rarity_label.name = 'RarityLabel'
	rarity_label.add_theme_font_size_override('font_size', 16)
	rarity_label.add_theme_color_override('font_color', Color(0.957, 0.784, 0.267))
	header.add_child(rarity_label)

	var category_label = Label.new()
	category_label.name = 'CategoryLabel'
	category_label.add_theme_font_size_override('font_size', 12)
	category_label.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	category_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_RIGHT
	category_label.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	header.add_child(category_label)

	# スプライト
	var sprite_container = CenterContainer.new()
	sprite_container.custom_minimum_size = Vector2(0, 148)
	vbox.add_child(sprite_container)

	var sprite = TextureRect.new()
	sprite.name = 'Sprite'
	sprite.custom_minimum_size = Vector2(128, 128)
	sprite.expand_mode = TextureRect.EXPAND_IGNORE_SIZE
	sprite.stretch_mode = TextureRect.STRETCH_KEEP_ASPECT_CENTERED
	sprite_container.add_child(sprite)
	_sprite_node = sprite

	# 名前
	var name_label = Label.new()
	name_label.name = 'NameLabel'
	name_label.add_theme_font_size_override('font_size', 22)
	name_label.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
	name_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	vbox.add_child(name_label)

	# パラメータ効果
	var effects_label = Label.new()
	effects_label.name = 'EffectsLabel'
	effects_label.add_theme_font_size_override('font_size', 13)
	effects_label.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
	effects_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	effects_label.autowrap_mode = TextServer.AUTOWRAP_WORD
	vbox.add_child(effects_label)

	var sep = HSeparator.new()
	vbox.add_child(sep)

	# ヒントテキスト
	var hint_label = Label.new()
	hint_label.name = 'HintLabel'
	hint_label.add_theme_font_size_override('font_size', 11)
	hint_label.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	hint_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	hint_label.autowrap_mode = TextServer.AUTOWRAP_WORD
	vbox.add_child(hint_label)

	# 配置ボタン
	var btn = Button.new()
	btn.name = 'PlaceButton'
	btn.text = '席に座らせる →'
	btn.add_theme_font_size_override('font_size', 14)
	var btn_style = StyleBoxFlat.new()
	btn_style.bg_color = Color(0.290, 0.565, 0.851)  # ブルー
	btn_style.corner_radius_top_left = 8
	btn_style.corner_radius_top_right = 8
	btn_style.corner_radius_bottom_left = 8
	btn_style.corner_radius_bottom_right = 8
	btn.add_theme_stylebox_override('normal', btn_style)
	btn.add_theme_color_override('font_color', Color.WHITE)
	btn.pressed.connect(_on_place_button_pressed)
	vbox.add_child(btn)

func _on_student_drawn(student_data: Dictionary) -> void:
	_current_student = student_data
	_update_card_display()
	_animate_in()

func _update_card_display() -> void:
	if _current_student.is_empty():
		return
	var content = get_node_or_null('CardPanel/Content')
	if content == null:
		return

	var rarity = _current_student.get('rarity', 1)
	var rarity_label = content.get_node_or_null('Header/RarityLabel')
	if rarity_label:
		rarity_label.text = '★'.repeat(rarity)

	var category_names = {
		'honor': '優等生タイプ', 'idol': 'アイドルタイプ',
		'yankee': 'ヤンキータイプ', 'entertainer': 'エンタメタイプ',
		'wildcard': 'ワイルドカード'
	}
	var cat_label = content.get_node_or_null('Header/CategoryLabel')
	if cat_label:
		cat_label.text = category_names.get(_current_student.get('category', ''), '？')

	# スプライト読み込み（直接参照を使う）
	if _sprite_node:
		var sprite_path = 'res://assets/sprites/' + _current_student.get('id', '') + '_48x48.png'
		var sprite_tex = _load_texture(sprite_path)
		_sprite_node.texture = sprite_tex  # null でもクリアとして機能する

	var name_label = content.get_node_or_null('NameLabel')
	if name_label:
		name_label.text = _current_student.get('name', '？')

	var base_params = _current_student.get('base_params', {})
	var effects_parts = []
	for param_id in ['study', 'romance', 'friendship', 'popularity']:
		var delta = base_params.get(param_id, 0)
		if delta != 0:
			var icon = PARAM_ICONS.get(param_id, '')
			var sign = '+' if delta > 0 else ''
			effects_parts.append('%s%s%d' % [icon, sign, delta])
	var effects_label = content.get_node_or_null('EffectsLabel')
	if effects_label:
		effects_label.text = '  '.join(effects_parts) if effects_parts else '（効果なし）'

	var hint_label = content.get_node_or_null('HintLabel')
	if hint_label:
		hint_label.text = '「%s」' % _current_student.get('hint_text', '')

	# カード枠色
	var panel = get_node_or_null('CardPanel')
	if panel:
		var style = panel.get_theme_stylebox('panel').duplicate()
		style.border_color = RARITY_COLORS.get(rarity, RARITY_COLORS[1])
		panel.add_theme_stylebox_override('panel', style)

func _animate_in() -> void:
	modulate.a = 0.0
	var saved_y = position.y
	position.y += 60
	var tween = create_tween()
	tween.tween_property(self, 'position:y', saved_y, 0.3).set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_BACK)
	tween.parallel().tween_property(self, 'modulate:a', 1.0, 0.25)

func _on_place_button_pressed() -> void:
	GameManager.go_to_placement()
	visible = false

func _on_phase_changed(phase: GameManager.Phase) -> void:
	visible = phase == GameManager.Phase.HOMEROOM

func _load_texture(res_path: String) -> Texture2D:
	var abs_path = ProjectSettings.globalize_path(res_path)
	var img = Image.new()
	if img.load(abs_path) == OK:
		return ImageTexture.create_from_image(img)
	return null
"

[node name="StudentCard" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = SubResource("GDScript_studentcard")
