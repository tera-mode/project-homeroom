[gd_scene load_steps=2 format=3 uid="uid://player_setup_scene"]

[sub_resource type="GDScript" id="GDScript_player_setup"]
script/source = "## PlayerSetup.tscn のスクリプト
## ゲーム開始前に主人公の名前・性別・席を設定する画面
extends Control

signal setup_complete(player_name: String, player_gender: String, player_seat: int)

const GRID_ROWS = 4
const GRID_COLS = 4
const SEAT_BTN_SIZE = 58

const COLOR_BG        = Color(0.10, 0.12, 0.18)
const COLOR_CARD      = Color(0.15, 0.17, 0.25, 0.97)
const COLOR_TEXT_MAIN = Color(0.95, 0.93, 0.88)
const COLOR_TEXT_SUB  = Color(0.65, 0.70, 0.80)
const COLOR_ACCENT    = Color(0.290, 0.565, 0.851)
const COLOR_GIRL      = Color(0.910, 0.357, 0.541)
const COLOR_BOY       = Color(0.290, 0.565, 0.851)
const COLOR_SEAT_EMPTY   = Color(0.22, 0.25, 0.35)
const COLOR_SEAT_SELECTED = Color(0.290, 0.565, 0.851)

var _gender: String = 'female'
var _selected_seat: int = -1
var _name_input: LineEdit = null
var _girl_btn: Button = null
var _boy_btn: Button = null
var _confirm_btn: Button = null
var _seat_buttons: Array = []

func _ready() -> void:
	visible = false
	_build_ui()
	GameManager.phase_changed.connect(_on_phase_changed)

func _on_phase_changed(phase: GameManager.Phase) -> void:
	visible = (phase == GameManager.Phase.PLAYER_SETUP)
	if visible:
		_reset_state()

func _reset_state() -> void:
	_gender = 'female'
	_selected_seat = -1
	if _name_input:
		_name_input.text = ''
	_update_gender_buttons()
	_update_seat_buttons()
	_update_confirm_btn()

func _build_ui() -> void:
	# 背景
	var bg = ColorRect.new()
	bg.color = COLOR_BG
	bg.anchor_right = 1.0
	bg.anchor_bottom = 1.0
	add_child(bg)

	# 中央カード
	var card = Panel.new()
	card.name = 'Card'
	var card_style = StyleBoxFlat.new()
	card_style.bg_color = COLOR_CARD
	card_style.corner_radius_top_left = 16
	card_style.corner_radius_top_right = 16
	card_style.corner_radius_bottom_left = 16
	card_style.corner_radius_bottom_right = 16
	card_style.border_color = Color(0.4, 0.5, 0.8, 0.5)
	card_style.set_border_width_all(2)
	card_style.content_margin_left = 30
	card_style.content_margin_right = 30
	card_style.content_margin_top = 24
	card_style.content_margin_bottom = 24
	card.add_theme_stylebox_override('panel', card_style)
	card.anchor_left = 0.5
	card.anchor_right = 0.5
	card.anchor_top = 0.5
	card.anchor_bottom = 0.5
	card.offset_left = -280
	card.offset_right = 280
	card.offset_top = -310
	card.offset_bottom = 310
	add_child(card)

	var vbox = VBoxContainer.new()
	vbox.anchor_right = 1.0
	vbox.anchor_bottom = 1.0
	vbox.add_theme_constant_override('separation', 16)
	card.add_child(vbox)

	# タイトル
	var title_lbl = Label.new()
	title_lbl.text = 'あなたのことを教えてください'
	title_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	title_lbl.add_theme_font_size_override('font_size', 20)
	title_lbl.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
	vbox.add_child(title_lbl)

	# 区切り線
	vbox.add_child(_make_separator())

	# 性別行
	var gender_row = HBoxContainer.new()
	gender_row.add_theme_constant_override('separation', 12)
	vbox.add_child(gender_row)

	var gender_lbl = Label.new()
	gender_lbl.text = '性別：'
	gender_lbl.add_theme_font_size_override('font_size', 15)
	gender_lbl.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	gender_lbl.vertical_alignment = VERTICAL_ALIGNMENT_CENTER
	gender_row.add_child(gender_lbl)

	_girl_btn = _make_toggle_button('女の子', COLOR_GIRL)
	_girl_btn.pressed.connect(_on_girl_pressed)
	gender_row.add_child(_girl_btn)

	_boy_btn = _make_toggle_button('男の子', COLOR_BOY)
	_boy_btn.pressed.connect(_on_boy_pressed)
	gender_row.add_child(_boy_btn)

	# 名前行
	var name_row = HBoxContainer.new()
	name_row.add_theme_constant_override('separation', 12)
	vbox.add_child(name_row)

	var name_lbl = Label.new()
	name_lbl.text = '名前：'
	name_lbl.add_theme_font_size_override('font_size', 15)
	name_lbl.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	name_lbl.vertical_alignment = VERTICAL_ALIGNMENT_CENTER
	name_row.add_child(name_lbl)

	_name_input = LineEdit.new()
	_name_input.placeholder_text = '名前を入力してください'
	_name_input.add_theme_font_size_override('font_size', 15)
	_name_input.add_theme_color_override('font_color', COLOR_TEXT_MAIN)
	_name_input.custom_minimum_size = Vector2(220, 36)
	_name_input.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	_name_input.text_changed.connect(_on_name_changed)
	var input_style = StyleBoxFlat.new()
	input_style.bg_color = Color(0.08, 0.10, 0.18)
	input_style.border_color = Color(0.4, 0.5, 0.8, 0.6)
	input_style.set_border_width_all(2)
	input_style.corner_radius_top_left = 6
	input_style.corner_radius_top_right = 6
	input_style.corner_radius_bottom_left = 6
	input_style.corner_radius_bottom_right = 6
	input_style.content_margin_left = 8
	input_style.content_margin_right = 8
	input_style.content_margin_top = 6
	input_style.content_margin_bottom = 6
	_name_input.add_theme_stylebox_override('normal', input_style)
	_name_input.add_theme_stylebox_override('focus', input_style)
	name_row.add_child(_name_input)

	# 席選択ラベル
	var seat_lbl = Label.new()
	seat_lbl.text = 'あなたの席を選んでください（4×4グリッド）'
	seat_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	seat_lbl.add_theme_font_size_override('font_size', 14)
	seat_lbl.add_theme_color_override('font_color', COLOR_TEXT_SUB)
	vbox.add_child(seat_lbl)

	# 席グリッド
	var grid_container = GridContainer.new()
	grid_container.columns = GRID_COLS
	grid_container.add_theme_constant_override('h_separation', 6)
	grid_container.add_theme_constant_override('v_separation', 6)
	grid_container.size_flags_horizontal = Control.SIZE_SHRINK_CENTER
	vbox.add_child(grid_container)

	_seat_buttons = []
	for i in range(GRID_ROWS * GRID_COLS):
		var seat_btn = Button.new()
		seat_btn.custom_minimum_size = Vector2(SEAT_BTN_SIZE, SEAT_BTN_SIZE)
		seat_btn.text = str(i + 1)
		seat_btn.add_theme_font_size_override('font_size', 12)
		_apply_seat_style(seat_btn, false)
		seat_btn.pressed.connect(_on_seat_pressed.bind(i))
		grid_container.add_child(seat_btn)
		_seat_buttons.append(seat_btn)

	# 区切り線
	vbox.add_child(_make_separator())

	# はじめる！ボタン
	_confirm_btn = Button.new()
	_confirm_btn.text = 'はじめる！'
	_confirm_btn.add_theme_font_size_override('font_size', 20)
	_confirm_btn.disabled = true
	var confirm_style_normal = StyleBoxFlat.new()
	confirm_style_normal.bg_color = COLOR_ACCENT
	confirm_style_normal.corner_radius_top_left = 12
	confirm_style_normal.corner_radius_top_right = 12
	confirm_style_normal.corner_radius_bottom_left = 12
	confirm_style_normal.corner_radius_bottom_right = 12
	_confirm_btn.add_theme_stylebox_override('normal', confirm_style_normal)
	var confirm_style_hover = confirm_style_normal.duplicate()
	confirm_style_hover.bg_color = COLOR_ACCENT.lightened(0.15)
	_confirm_btn.add_theme_stylebox_override('hover', confirm_style_hover)
	var confirm_style_disabled = confirm_style_normal.duplicate()
	confirm_style_disabled.bg_color = Color(0.3, 0.3, 0.4, 0.5)
	_confirm_btn.add_theme_stylebox_override('disabled', confirm_style_disabled)
	_confirm_btn.add_theme_color_override('font_color', Color.WHITE)
	_confirm_btn.add_theme_color_override('font_disabled_color', Color(0.5, 0.5, 0.6))
	_confirm_btn.pressed.connect(_on_confirm_pressed)
	vbox.add_child(_confirm_btn)

	_update_gender_buttons()

func _make_separator() -> HSeparator:
	var sep = HSeparator.new()
	var sep_style = StyleBoxFlat.new()
	sep_style.bg_color = Color(0.4, 0.5, 0.8, 0.3)
	sep_style.content_margin_top = 1
	sep_style.content_margin_bottom = 1
	sep.add_theme_stylebox_override('separator', sep_style)
	return sep

func _make_toggle_button(label: String, color: Color) -> Button:
	var btn = Button.new()
	btn.text = label
	btn.add_theme_font_size_override('font_size', 14)
	btn.custom_minimum_size = Vector2(90, 36)
	var style_off = StyleBoxFlat.new()
	style_off.bg_color = Color(0.2, 0.22, 0.32)
	style_off.border_color = color.darkened(0.3)
	style_off.set_border_width_all(2)
	style_off.corner_radius_top_left = 8
	style_off.corner_radius_top_right = 8
	style_off.corner_radius_bottom_left = 8
	style_off.corner_radius_bottom_right = 8
	btn.add_theme_stylebox_override('normal', style_off)
	btn.set_meta('color', color)
	btn.add_theme_color_override('font_color', Color(0.7, 0.75, 0.85))
	return btn

func _apply_seat_style(btn: Button, selected: bool) -> void:
	var style = StyleBoxFlat.new()
	style.bg_color = COLOR_SEAT_SELECTED if selected else COLOR_SEAT_EMPTY
	style.border_color = COLOR_SEAT_SELECTED.lightened(0.2) if selected else Color(0.35, 0.40, 0.55)
	style.set_border_width_all(2)
	style.corner_radius_top_left = 6
	style.corner_radius_top_right = 6
	style.corner_radius_bottom_left = 6
	style.corner_radius_bottom_right = 6
	btn.add_theme_stylebox_override('normal', style)
	btn.add_theme_stylebox_override('hover', style)
	btn.add_theme_stylebox_override('pressed', style)
	btn.add_theme_color_override('font_color', Color.WHITE if selected else COLOR_TEXT_SUB)

func _on_girl_pressed() -> void:
	_gender = 'female'
	_update_gender_buttons()

func _on_boy_pressed() -> void:
	_gender = 'male'
	_update_gender_buttons()

func _update_gender_buttons() -> void:
	if _girl_btn == null or _boy_btn == null:
		return
	var girl_color = COLOR_GIRL
	var boy_color  = COLOR_BOY

	var girl_on = StyleBoxFlat.new()
	girl_on.bg_color = girl_color
	girl_on.corner_radius_top_left = 8
	girl_on.corner_radius_top_right = 8
	girl_on.corner_radius_bottom_left = 8
	girl_on.corner_radius_bottom_right = 8
	girl_on.set_border_width_all(2)
	girl_on.border_color = girl_color.lightened(0.2)

	var girl_off = StyleBoxFlat.new()
	girl_off.bg_color = Color(0.2, 0.22, 0.32)
	girl_off.corner_radius_top_left = 8
	girl_off.corner_radius_top_right = 8
	girl_off.corner_radius_bottom_left = 8
	girl_off.corner_radius_bottom_right = 8
	girl_off.set_border_width_all(2)
	girl_off.border_color = girl_color.darkened(0.3)

	var boy_on = StyleBoxFlat.new()
	boy_on.bg_color = boy_color
	boy_on.corner_radius_top_left = 8
	boy_on.corner_radius_top_right = 8
	boy_on.corner_radius_bottom_left = 8
	boy_on.corner_radius_bottom_right = 8
	boy_on.set_border_width_all(2)
	boy_on.border_color = boy_color.lightened(0.2)

	var boy_off = StyleBoxFlat.new()
	boy_off.bg_color = Color(0.2, 0.22, 0.32)
	boy_off.corner_radius_top_left = 8
	boy_off.corner_radius_top_right = 8
	boy_off.corner_radius_bottom_left = 8
	boy_off.corner_radius_bottom_right = 8
	boy_off.set_border_width_all(2)
	boy_off.border_color = boy_color.darkened(0.3)

	if _gender == 'female':
		_girl_btn.add_theme_stylebox_override('normal', girl_on)
		_girl_btn.add_theme_stylebox_override('hover', girl_on)
		_girl_btn.add_theme_color_override('font_color', Color.WHITE)
		_boy_btn.add_theme_stylebox_override('normal', boy_off)
		_boy_btn.add_theme_stylebox_override('hover', boy_off)
		_boy_btn.add_theme_color_override('font_color', Color(0.7, 0.75, 0.85))
	else:
		_girl_btn.add_theme_stylebox_override('normal', girl_off)
		_girl_btn.add_theme_stylebox_override('hover', girl_off)
		_girl_btn.add_theme_color_override('font_color', Color(0.7, 0.75, 0.85))
		_boy_btn.add_theme_stylebox_override('normal', boy_on)
		_boy_btn.add_theme_stylebox_override('hover', boy_on)
		_boy_btn.add_theme_color_override('font_color', Color.WHITE)

func _on_seat_pressed(index: int) -> void:
	_selected_seat = index
	_update_seat_buttons()
	_update_confirm_btn()

func _update_seat_buttons() -> void:
	for i in range(_seat_buttons.size()):
		_apply_seat_style(_seat_buttons[i], i == _selected_seat)

func _on_name_changed(_text: String) -> void:
	_update_confirm_btn()

func _update_confirm_btn() -> void:
	if _confirm_btn == null or _name_input == null:
		return
	_confirm_btn.disabled = _name_input.text.strip_edges().is_empty() or _selected_seat < 0

func _on_confirm_pressed() -> void:
	var name_val = _name_input.text.strip_edges()
	if name_val.is_empty() or _selected_seat < 0:
		return
	var tween = create_tween()
	tween.tween_property(self, 'modulate:a', 0.0, 0.3)
	tween.tween_callback(func():
		visible = false
		setup_complete.emit(name_val, _gender, _selected_seat)
	)
"

[node name="PlayerSetup" type="Control"]
anchor_right = 1.0
anchor_bottom = 1.0
script = SubResource("GDScript_player_setup")
