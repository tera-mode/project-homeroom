; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="転校生ガチャ！"
config/name_localized={
"en": "Transfer Student Gacha!"
}
config/description="毎日やってくる転校生を、たった16席の教室に座らせろ。"
config/version="0.1"
run/main_scene="res://scenes/Main.tscn"
config/use_custom_user_dir=true
config/custom_user_dir_name="project-homeroom"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

GameManager="*res://scripts/GameManager.gd"
StudentDB="*res://scripts/StudentDB.gd"
SaveManager="*res://scripts/SaveManager.gd"
CharacterState="*res://scripts/CharacterState.gd"
FriendshipManager="*res://scripts/FriendshipManager.gd"
LessonManager="*res://scripts/LessonManager.gd"
FulfillmentCalc="*res://scripts/FulfillmentCalc.gd"
AbilityEngine="*res://scripts/AbilityEngine.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.98, 0.984, 0.941, 1)
